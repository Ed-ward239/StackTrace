# StackTrace targets Unix shells and POSIX toolchains. Force LF so scripts and
# sources stay valid when checked out on macOS / Linux / Raspberry Pi, even
# when authored on Windows.
*.sh        text eol=lf
*.cpp       text eol=lf
*.hpp       text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.conf      text eol=lf
*.snippet   text eol=lf
*.md        text eol=lf
CMakeLists.txt text eol=lf
newsboat_urls  text eol=lf

# Binary assets
*.png       binary
